{
  "$schema": "component-tokens",
  "$description": "Button component tokens. All values reference semantic tokens — no hard-coded colors.",
  "button": {
    "primary": {
      "background": {
        "default":  { "value": "{color.primary.default}",  "type": "color" },
        "hover":    { "value": "{color.primary.hover}",    "type": "color" },
        "active":   { "value": "{color.primary.active}",   "type": "color" },
        "disabled": { "value": "{color.foreground.subtle}", "type": "color" },
        "focus":    { "value": "{color.primary.default}",  "type": "color" }
      },
      "foreground": {
        "default":  { "value": "{color.primary.foreground}", "type": "color" },
        "disabled": { "value": "{color.foreground.muted}",   "type": "color" }
      },
      "border": {
        "default":  { "value": "transparent",               "type": "color" },
        "focus":    { "value": "{color.primary.active}",    "type": "color" }
      },
      "shadow": {
        "focus": { "value": "0 0 0 3px {color.primary.default}", "type": "boxShadow" }
      }
    },
    "secondary": {
      "background": {
        "default":  { "value": "{color.surface.card}",       "type": "color" },
        "hover":    { "value": "{color.background.subtle}",  "type": "color" },
        "active":   { "value": "{color.border.default}",     "type": "color" },
        "disabled": { "value": "{color.background.subtle}",  "type": "color" },
        "focus":    { "value": "{color.surface.card}",       "type": "color" }
      },
      "foreground": {
        "default":  { "value": "{color.foreground.default}", "type": "color" },
        "disabled": { "value": "{color.foreground.muted}",   "type": "color" }
      },
      "border": {
        "default":  { "value": "{color.border.default}",     "type": "color" },
        "focus":    { "value": "{color.primary.default}",    "type": "color" }
      }
    },
    "ghost": {
      "background": {
        "default":  { "value": "transparent",               "type": "color" },
        "hover":    { "value": "{color.background.subtle}", "type": "color" },
        "active":   { "value": "{color.border.muted}",      "type": "color" },
        "disabled": { "value": "transparent",               "type": "color" },
        "focus":    { "value": "transparent",               "type": "color" }
      },
      "foreground": {
        "default":  { "value": "{color.foreground.default}", "type": "color" },
        "disabled": { "value": "{color.foreground.muted}",   "type": "color" }
      },
      "border": {
        "default": { "value": "transparent", "type": "color" },
        "focus":   { "value": "{color.primary.default}", "type": "color" }
      }
    },
    "destructive": {
      "background": {
        "default":  { "value": "{color.error.default}", "type": "color" },
        "hover":    { "value": "{color.error.default}", "type": "color" },
        "active":   { "value": "{color.error.default}", "type": "color" },
        "disabled": { "value": "{color.foreground.subtle}", "type": "color" }
      },
      "foreground": {
        "default":  { "value": "{color.error.foreground}", "type": "color" },
        "disabled": { "value": "{color.foreground.muted}", "type": "color" }
      },
      "border": {
        "default": { "value": "transparent", "type": "color" }
      }
    },
    "radius": { "value": "{shape.button}", "type": "borderRadius" }
  }
}

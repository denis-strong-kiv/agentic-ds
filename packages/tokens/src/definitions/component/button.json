{
  "$schema": "component-tokens",
  "$description": "Button component tokens — base default state only. Hover/active are derived in CSS via OKLCH relative color syntax (no separate tokens needed). Inverted variants use oklch(100% 0 0) for white.",
  "button": {
    "primary": {
      "background": { "value": "{color.primary.default}",   "type": "color" },
      "foreground": { "value": "{color.primary.foreground}", "type": "color" },
      "border":     { "value": "transparent",               "type": "color" }
    },
    "secondary": {
      "background": { "value": "transparent",               "type": "color" },
      "foreground": { "value": "{color.foreground.default}", "type": "color" },
      "border":     { "value": "{color.border.default}",    "type": "color" }
    },
    "tertiary": {
      "$description": "Figma 'Tertiary' — ghost style with neutral foreground label.",
      "background": { "value": "transparent",               "type": "color" },
      "foreground": { "value": "{color.foreground.default}", "type": "color" },
      "border":     { "value": "transparent",               "type": "color" }
    },
    "neutral": {
      "$description": "Figma 'Default' — dark filled button using foreground/background inversion.",
      "background": { "value": "{color.foreground.default}", "type": "color" },
      "foreground": { "value": "{color.background.default}", "type": "color" },
      "border":     { "value": "transparent",               "type": "color" }
    },
    "inverted-primary": {
      "$description": "For dark surfaces. White fill; hover/active use oklch(100% 0 0 / alpha).",
      "background": { "value": "oklch(100% 0 0)",           "type": "color" },
      "foreground": { "value": "{color.foreground.default}", "type": "color" },
      "border":     { "value": "transparent",               "type": "color" }
    },
    "inverted-secondary": {
      "$description": "For dark surfaces. White outline; hover/active fill use oklch(100% 0 0 / alpha).",
      "background": { "value": "transparent",               "type": "color" },
      "foreground": { "value": "oklch(100% 0 0)",           "type": "color" },
      "border":     { "value": "oklch(100% 0 0)",           "type": "color" }
    },
    "inverted-tertiary": {
      "$description": "For dark surfaces. White label only; hover/active fill use oklch(100% 0 0 / alpha).",
      "background": { "value": "transparent",               "type": "color" },
      "foreground": { "value": "oklch(100% 0 0)",           "type": "color" },
      "border":     { "value": "transparent",               "type": "color" }
    },
    "ghost": {
      "$description": "Kept for backward compatibility — transparent bg, foreground-colored label.",
      "background": { "value": "transparent",               "type": "color" },
      "foreground": { "value": "{color.foreground.default}", "type": "color" },
      "border":     { "value": "transparent",               "type": "color" }
    },
    "destructive": {
      "background": { "value": "{color.error.default}",     "type": "color" },
      "foreground": { "value": "{color.error.foreground}",  "type": "color" },
      "border":     { "value": "transparent",               "type": "color" }
    },
    "radius": { "value": "{shape.button}", "type": "borderRadius" }
  }
}

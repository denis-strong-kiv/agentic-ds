{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@travel/ui/components/*": ["../../packages/ui/src/components/*"],
      "@travel/ui/brand/*": ["../../packages/ui/src/brand/*"],
      "@travel/ui/hooks": ["../../packages/ui/src/hooks/index.ts"],
      "@travel/ui/hooks/*": ["../../packages/ui/src/hooks/*"],
      "@travel/ui/utils/*": ["../../packages/ui/src/utils/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
